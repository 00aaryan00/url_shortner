<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        background: linear-gradient(135deg, #f5efe6 0%, #ebdfcf 100%);
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        color: #1f2933;
      }

      .card {
        max-width: 520px;
        background: rgba(255, 251, 245, 0.94);
        border: 1px solid #e5d4c0;
        border-radius: 22px;
        padding: 32px;
        box-shadow: 0 24px 70px rgba(100, 67, 31, 0.15);
        text-align: center;
      }

      h1 {
        margin-top: 0;
      }

      p {
        color: #52606d;
        line-height: 1.6;
      }

      a {
        color: #b44d12;
        text-decoration: none;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <section class="card">
      <h1><%= title %></h1>
      <p><%= message %></p>
      <p><a href="/">Back to home</a></p>
    </section>
  </body>
</html>
