<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Short Links Dashboard</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f4efe7;
        --surface: #fffaf2;
        --surface-strong: #ffffff;
        --text: #1f2933;
        --muted: #52606d;
        --accent: #b44d12;
        --accent-dark: #8d3a0c;
        --border: #e5d4c0;
        --success-bg: #e8f7ee;
        --success-text: #1f6f43;
        --error-bg: #fdecec;
        --error-text: #9b1c1c;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #f7efe5 0%, #efe4d6 100%);
        color: var(--text);
      }

      .page {
        width: min(960px, calc(100% - 32px));
        margin: 40px auto;
      }

      .card {
        background: rgba(255, 250, 242, 0.92);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 18px 60px rgba(100, 67, 31, 0.12);
        backdrop-filter: blur(8px);
      }

      .header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        margin-bottom: 24px;
      }

      .header h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3rem);
      }

      .header p {
        margin: 6px 0 0;
        color: var(--muted);
      }

      .logout {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
      }

      .message {
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 16px;
      }

      .message.success {
        background: var(--success-bg);
        color: var(--success-text);
      }

      .message.error {
        background: var(--error-bg);
        color: var(--error-text);
      }

      form {
        display: grid;
        gap: 12px;
      }

      label {
        font-weight: 600;
      }

      input {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid var(--border);
        border-radius: 12px;
        font-size: 1rem;
      }

      button {
        width: fit-content;
        border: none;
        border-radius: 999px;
        background: var(--accent);
        color: white;
        padding: 12px 18px;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
      }

      button:hover {
        background: var(--accent-dark);
      }

      .generated-link {
        margin-top: 18px;
        padding: 16px;
        border-radius: 14px;
        background: var(--surface-strong);
        border: 1px solid var(--border);
      }

      .generated-link a,
      table a {
        color: var(--accent);
      }

      .table-wrap {
        margin-top: 28px;
        overflow-x: auto;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        background: var(--surface-strong);
        border-radius: 16px;
        overflow: hidden;
      }

      th,
      td {
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
        text-align: left;
        vertical-align: top;
      }

      th {
        background: #f6e7d5;
      }

      tr:last-child td {
        border-bottom: none;
      }

      .empty {
        margin-top: 20px;
        color: var(--muted);
      }

      @media (max-width: 700px) {
        .header {
          flex-direction: column;
          align-items: flex-start;
        }

        button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main class="page">
      <section class="card">
        <div class="header">
          <div>
            <h1>Short Links Dashboard</h1>
            <p>Create, manage, and track the links attached to your account.</p>
          </div>
          <a class="logout" href="/user/logout">Log out</a>
        </div>

        <% if (error) { %>
        <div class="message error"><%= error %></div>
        <% } %>

        <% if (success) { %>
        <div class="message success"><%= success %></div>
        <% } %>

        <form method="POST" action="/url">
          <label for="url">Paste a destination URL</label>
          <input
            id="url"
            type="text"
            name="url"
            placeholder="https://example.com/article"
            value="<%= formData?.url || '' %>"
          />
          <button type="submit">Create short URL</button>
        </form>

        <% if (generatedShortUrl) { %>
        <div class="generated-link">
          <strong>New short URL:</strong>
          <a href="<%= generatedShortUrl %>" target="_blank" rel="noreferrer"><%= generatedShortUrl %></a>
        </div>
        <% } %>

        <div class="table-wrap">
          <% if (urls && urls.length) { %>
          <table>
            <thead>
              <tr>
                <th>Short URL</th>
                <th>Destination</th>
                <th>Clicks</th>
                <th>Analytics</th>
              </tr>
            </thead>
            <tbody>
              <% urls.forEach((url) => { %>
              <tr>
                <td>
                  <a href="<%= `${baseUrl}/url/${url.shortId}` %>" target="_blank" rel="noreferrer">
                    <%= `${baseUrl}/url/${url.shortId}` %>
                  </a>
                </td>
                <td><%= url.redirectURL %></td>
                <td><%= url.visitHistory.length %></td>
                <td>
                  <a href="/url/analytics/<%= url.shortId %>" target="_blank" rel="noreferrer">View JSON</a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } else { %>
          <p class="empty">You have not created any short links yet.</p>
          <% } %>
        </div>
      </section>
    </main>
  </body>
</html>
